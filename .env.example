# ZARKARI Platform Environment Variables

# Site — required for OG/social previews (WhatsApp, Facebook) and Stripe absolute URLs
# Production: https://zarkari.co.uk
# Cloudflare tunnel testing: set to your current https://xxxx.trycloudflare.com URL, then restart dev
NEXT_PUBLIC_SITE_URL=https://zarkari.co.uk

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/zarkari

# Stripe (retail checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=orders@zarkari.co.uk

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zarkari-files
R2_PUBLIC_URL=https://files.zarkari.co.uk

# Soro blog webhook
SORO_WEBHOOK_SECRET=your-soro-secret

# Meta / analytics
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel Cron auth
CRON_SECRET=your-random-secret

# WhatsApp (optional footer link)
NEXT_PUBLIC_WHATSAPP_NUMBER=447474164734

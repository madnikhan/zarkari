# ZARKARI Platform Environment Variables

# Site — required for OG/social previews (WhatsApp, Facebook) and Stripe absolute URLs
# Production: https://zarkari.co.uk
# Cloudflare tunnel testing: set to your current https://xxxx.trycloudflare.com URL, then restart dev
NEXT_PUBLIC_SITE_URL=https://zarkari.co.uk

# Session signing (required in production)
SESSION_SECRET=generate_a_long_random_string

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/zarkari

# Stripe (retail checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=orders@zarkari.co.uk

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zarkari-files
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Direct browser→R2 uploads (video/audio/large files). Default 200 MB.
MAX_DIRECT_UPLOAD_BYTES=209715200

# R2 CORS (required for direct browser→R2 video uploads): bucket Settings → CORS
# AllowedOrigins: http://localhost:3000, https://www.zarkari.co.uk, https://zarkari.co.uk
# AllowedMethods: GET, PUT, HEAD — AllowedHeaders: *

# Soro blog webhook
SORO_WEBHOOK_SECRET=your-soro-secret

# Meta / analytics
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel Cron auth
CRON_SECRET=your-random-secret

# WhatsApp (optional footer link)
NEXT_PUBLIC_WHATSAPP_NUMBER=447474164734

# Meta — Facebook Messenger + Instagram DMs (Social Inbox)
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
# Optional alias for META_APP_SECRET when verifying webhook signatures
META_WEBHOOK_SECRET=

# WhatsApp Business Cloud API (two-way inbox sync)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

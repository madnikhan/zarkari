rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isStaff() {
      return request.auth != null &&
        request.auth.token.role in ['admin', 'supplier'];
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    function isSupplier() {
      return request.auth != null && request.auth.token.role == 'supplier';
    }

    function isCustomerForOrder(orderId) {
      return request.auth != null &&
        request.auth.token.role == 'customer' &&
        request.auth.token.orderId == orderId;
    }

    match /live_orders/{orderId} {
      allow read: if isStaff() || isCustomerForOrder(orderId);
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isAdmin() || isCustomerForOrder(orderId);
        allow write: if false;
      }

      match /supplier_messages/{messageId} {
        allow read: if isAdmin() || isSupplier();
        allow write: if false;
      }
    }

    match /staff_inbox/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /supplier_inbox/{supplierId} {
      allow read: if isSupplier() && request.auth.token.supplierId == supplierId;
      allow write: if false;
    }
  }
}

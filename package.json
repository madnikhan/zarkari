{
  "name": "zarkari",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "db:generate": "npm run generate --workspace=@zarkari/db",
    "db:push": "npm run push --workspace=@zarkari/db",
    "db:seed": "tsx scripts/seed-db.ts",
    "db:migrate-size-variants": "tsx scripts/migrate-size-variants.ts",
    "db:seed-sample": "tsx scripts/seed-sample-data.ts",
    "db:clear-sample": "tsx scripts/clear-sample-data.ts",
    "test:r2": "tsx scripts/test-r2.ts",
    "audit:admin": "tsx scripts/admin-audit.ts"
  }
}
